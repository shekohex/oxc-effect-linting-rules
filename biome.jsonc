{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "plugins": [
    "./node_modules/@catenarycloud/linteffect/rules/no-react-state.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-if-statement.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-switch-statement.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-ternary.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-return-null.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-pipe-ladder.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-flatmap-ladder.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-ladder.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-nested-effect-call.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-as.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-wrapper-alias.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-call-tower.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-option-as.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-arrow-ladder.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-branch-in-object.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-iife-wrapper.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-return-in-arrow.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-atom-registry-effect-sync.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-family-collection-read.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-never.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-type-alias.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-async.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-fn-generator.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-sync-console.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-do.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-bind.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-nested-effect-gen.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-runtime-runfork.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-match-void-branch.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-match-effect-branch.grit",
    "./node_modules/@catenarycloud/linteffect/rules/warn-effect-sync-wrapper.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-side-effect-wrapper.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-all-step-sequencing.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-manual-data-guard.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-effect-orElse-ladder.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-render-side-effects.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-return-in-callback.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-wrapgraphql-catchall.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-model-overlay-cast.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-unknown-boolean-coercion-helper.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-fromnullable-nullish-coalesce.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-option-boolean-normalization.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-try-catch.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-string-sentinel-return.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-string-sentinel-const.grit",
    "./node_modules/@catenarycloud/linteffect/rules/no-manual-effect-channels.grit",
    "./node_modules/@catenarycloud/linteffect/rules/prevent-dynamic-imports.grit"
  ]
}
